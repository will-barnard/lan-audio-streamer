# LAN Audio Bridge — Windows receiver configuration
# Copy to ".env" and edit. Lines starting with # are ignored.

# ---- Listen ----
# UDP ports. Must match the sender's .env.
AUDIO_PORT=45678
CONTROL_PORT=45679
DISCOVERY_PORT=45680

# ---- Playback ----
# Render device to play the received audio into. This should be the VB-CABLE
# PLAYBACK endpoint. Your apps (OBS/Discord/DAW) then select "CABLE Output"
# as their microphone. Run:
#     dotnet run -- --list-devices
# to see exact names.
AUDIO_OUTPUT_DEVICE=CABLE Input

# ---- Audio format (must match sender) ----
SAMPLE_RATE=48000
CHANNELS=2

# Jitter buffer depth in milliseconds. Higher = more robust to network jitter
# but more latency. Raise to 50 if audio is choppy on Wi-Fi.
JITTER_MS=30

# pcm (default) or opus (future hook)
CODEC=pcm

# ---- Identity / discovery ----
DEVICE_NAME=Windows-PC
# off (manual) or on (broadcast ANNOUNCE beacons so senders with RECEIVER_HOST=auto find us)
DISCOVERY=off
