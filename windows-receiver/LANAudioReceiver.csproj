<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>LANAudioReceiver</AssemblyName>
    <RootNamespace>LANAudioReceiver</RootNamespace>
    <!-- Windows-only (WASAPI + Media Foundation via NAudio). Build/run on Windows. -->
  </PropertyGroup>

  <ItemGroup>
    <!-- NAudio provides WASAPI output, device enumeration, and the resampler. -->
    <PackageReference Include="NAudio" Version="2.2.1" />
    <!-- To enable CODEC=opus later, uncomment (pure-C# Opus, no native dependency):
    <PackageReference Include="Concentus" Version="2.2.2" /> -->
  </ItemGroup>

</Project>
