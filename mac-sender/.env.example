# LAN Audio Bridge — macOS sender configuration
# Copy to ".env" and edit. Lines starting with # are ignored.

# ---- Destination ----
# The Windows PC's LAN IP address. Find it on Windows with `ipconfig`.
# Set to "auto" together with DISCOVERY=on to auto-detect the receiver.
RECEIVER_HOST=192.168.1.50

# UDP ports. Must match the receiver's .env.
AUDIO_PORT=45678
CONTROL_PORT=45679
DISCOVERY_PORT=45680

# ---- Capture ----
# Name of the input device to capture from. Run:
#     swift run LANAudioSender --list-devices
# to see available names. BlackHole is the usual choice.
AUDIO_INPUT_DEVICE=BlackHole 2ch

# ---- Audio format (must match receiver) ----
SAMPLE_RATE=48000
CHANNELS=2
# Packet size in milliseconds. 5 keeps datagrams under the Ethernet MTU.
FRAME_MS=5

# pcm (default, best quality/latency on a LAN) or opus (future hook)
CODEC=pcm

# ---- Identity / discovery ----
DEVICE_NAME=MacBook
# off (manual RECEIVER_HOST) or on (listen for receiver ANNOUNCE beacons)
DISCOVERY=off
